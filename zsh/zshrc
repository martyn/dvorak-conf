}

# Function: gitlin
# Usage:
#   gitlin <linear_issue_url>
# Example:
#   gitlin https://linear.app/levelheaded/issue/LEV-636/staging-build-fail
gitlin() {
  # Ensure a URL is provided.
  if [ "$#" -ne 1 ]; then
    echo "Usage: gitlin <linear_issue_url>"
    return 1
  fi

  # Check for modified tracked files only (ignoring untracked files).
  if ! git diff-index --quiet HEAD --; then
    echo "Error: Your working directory has modified tracked files. Please stash your changes before running this command."
    return 1
  fi

  local url="$1"

  # Split the URL by '/'.
  # For the URL:
  #   https://linear.app/levelheaded/issue/LEV-636/staging-build-fail
  # the resulting parts are:
  #   parts[1] = "https:"
  #   parts[2] = "" (empty)
  #   parts[3] = "linear.app"
  #   parts[4] = "levelheaded"
  #   parts[5] = "issue"
  #   parts[6] = "LEV-636"
  #   parts[7] = "staging-build-fail"
  IFS='/' read -A parts <<< "$url"

  if [ ${#parts[@]} -lt 7 ]; then
    echo "Error: Invalid URL format."
    return 1
  fi

  local issue_id="${parts[6]}"
  local desc_branch="${parts[7]}"

  # Convert issue ID to lowercase.
  local issue_id_lower
  issue_id_lower=$(echo "$issue_id" | tr '[:upper:]' '[:lower:]')

  # Construct the branch name in the form: staging-build-fail-lev-636.
  local branch_name="${desc_branch}-${issue_id_lower}"

  echo "Creating branch: $branch_name"

  # Execute the git commands.
  git checkout staging || return
  git pull || return
  git checkout -b "$branch_name" || return

  # Set the upstream to the remote branch with the same name.
  git push -u origin HEAD || return
  gh pr create --base staging --head "$branch_name" --title "$branch_name" --body "Closes issue $issue_id" || return

  echo "Branch '$branch_name' created and upstream set to origin/$branch_name."
}


