wt-open() {
  branch="$1"
  if [ -z "$branch" ]; then
    echo "Usage: wt-open <branch-name>"
    return 1
  fi
  git worktree add "worktrees/$branch" -b "$branch" && \
  cd "worktrees/$branch" && \
  git push -u origin "$branch"
}

wt-merge() {
  # If argument is given, use it; else, detect current branch
  repo_root=$(git rev-parse --show-toplevel)
  if [ -n "$1" ]; then
    branch="$1"
    worktree_path="worktrees/$branch"
  else
    branch=$(git rev-parse --abbrev-ref HEAD)
    # Detect worktree path from CWD
    # Assumes CWD is .../worktrees/<branch>
    worktree_path=$(realpath --relative-to="$repo_root" "$PWD")
    # If not in worktree, fallback to standard path
    if [[ "$worktree_path" != worktrees/* ]]; then
      worktree_path="worktrees/$branch"
    fi
    cd "$repo_root"
  fi

  gh pr merge --merge --delete-branch && git push origin --delete "$branch" 2> /dev/null
  git worktree remove "$worktree_path"
}

pr-create() {
  branch=$(git rev-parse --abbrev-ref HEAD)
  git push -u origin "$branch"
  gh pr create --fill --base main
}

wt-abort() {
  branch="$1"
  if [ -z "$branch" ]; then
    echo "Usage: wt-abort <branch-name>"
    return 1
  fi
  worktree_path="worktrees/$branch"

  # Attempt to close PR if it exists
  if gh pr view "$branch" &>/dev/null; then
    gh pr close "$branch" --delete-branch
  fi

  # Delete remote branch (ignore error if doesn't exist)
  git push origin --delete "$branch" 2>/dev/null

  # Remove worktree (force if needed)
  git worktree remove --force "$worktree_path" 2>/dev/null

  # Delete local branch if exists
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git branch -D "$branch"
  fi

  # Remove the directory if it still exists
  if [ -d "$worktree_path" ]; then
    rm -rf "$worktree_path"
  fi

  echo "✅ Worktree, branch, and PR for '$branch' nuked."
}

