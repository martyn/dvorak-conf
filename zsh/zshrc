# Function to write clipboard content to a file using xclip
pcl() {
    # Use patch.diff as the default filename if no argument is provided
    local outfile="${1:-patch.diff}"
    xclip -selection clipboard -o > "$outfile"
    echo "Clipboard content written to $outfile. running gptpatch"
    gptpatch $outfile
    echo "Removing $outfile"
    rm $outfile
}

