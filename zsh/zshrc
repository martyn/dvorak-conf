# Move files to the NAS and delete the local copy once the transfer verifies
archive() {
  local NAS=mikkel@192.168.1.154 DEST=archive
  [ $# -eq 0 ] && { echo "usage: archive <path> [path...]"; return 1; }
  ping -c1 -W2 192.168.1.154 >/dev/null 2>&1 || { echo "NAS unreachable, aborting"; return 1; }
  for src in "$@"; do
    [ -e "$src" ] || { echo "skip (not found): $src"; continue; }
    echo ">> $src"
    rsync -aH --remove-source-files --partial --info=progress2 "$src" "$NAS:$DEST/" \
      || { echo "!! transfer failed — nothing deleted: $src"; return 1; }
    [ -d "$src" ] && find "$src" -depth -type d -empty -delete
    echo "<< archived + removed local: $src"
  done
}

