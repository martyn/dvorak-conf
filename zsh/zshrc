wt-pull () {
  if [[ -z "$1" ]]; then
    echo "usage: wt-pull <pull-request-url | branch-name>"; return 1
  fi

  local input="$1"
  local branch

  # If the argument looks like a URL, ask GitHub CLI for the branch behind the PR
  if [[ "$input" =~ ^https?:// ]]; then
    # extract the numeric PR id (last slash-separated field)
    local pr=$(echo "$input" | awk -F'/' '{print $NF}')
    # require: gh CLI authenticated in this repo
    branch=$(gh pr view "$pr" --json headRefName -q .headRefName) || return
  else
    branch="$input"
  fi

  # Dir name: replace slashes with dashes so worktree names stay flat
  local dir="worktrees/$(echo "$branch" | tr '/' '-')"

  echo "⏩  Adding worktree $dir for branch $branch"
  git worktree add "$dir" "$branch" || return

  cd "$dir" || return
  echo "📦  [disabled] Installing dependencies…"

  # If there’s an .env two levels up, copy it for convenience
  [[ -f ../../.env ]] && cp ../../.env .

  echo "🚀  Launching dev server…"
  npm run dev
}
